# Copy to .env and replace every CHANGE_ME value before `make up`.

# ===== Project root =====
# Where all persistent data + configs live on the host.
AEGISCORE_ROOT=/opt/aegiscore

# ===== Runtime =====
# dev | staging | prod — surfaced to PHP as AEGISCORE_ENV.
AEGISCORE_ENV=dev

# ===== Laravel =====
# Generate once with `make artisan CMD="key:generate --show"` after first
# `composer install`, then paste the resulting base64: value here.
APP_KEY=
# Public URL Laravel uses for signed URLs, absolute route(), etc.
APP_URL=http://localhost

# ===== MariaDB =====
MARIADB_ROOT_PASSWORD=CHANGE_ME
MARIADB_DATABASE=aegiscore
MARIADB_USER=aegiscore
MARIADB_PASSWORD=CHANGE_ME

# ===== Redis =====
# Laravel cache / sessions / queues / Horizon all ride on this.
# Avoid $ ` " and \ in the password to keep healthcheck + command shell-safe.
REDIS_PASSWORD=CHANGE_ME
REDIS_MAXMEMORY=512mb

# ===== OpenSearch =====
# Phase 1: security plugin disabled (internal network only, no auth/TLS).
# When we put OpenSearch behind nginx + mTLS in prod, restore
# OPENSEARCH_ADMIN_PASSWORD here and flip DISABLE_SECURITY_PLUGIN off.

# ===== InfluxDB 2.x =====
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=CHANGE_ME
INFLUXDB_ADMIN_TOKEN=CHANGE_ME_LONG_RANDOM_TOKEN
INFLUXDB_ORG=aegiscore
INFLUXDB_BUCKET=primary

# ===== Neo4j =====
NEO4J_PASSWORD=CHANGE_ME
# Bolt auth user. Community edition only supports `neo4j`; Enterprise
# allows additional users but we don't rely on that in phase 1.
NEO4J_USER=neo4j
# Database name within the server. Phase 1 uses the single default DB.
NEO4J_DATABASE=neo4j

# Memory settings (dev defaults — small host / laptop).
# Prod recommendation for a dedicated 64G+ box:
#   NEO4J_HEAP_INIT=24G  NEO4J_HEAP_MAX=24G  NEO4J_PAGECACHE=24G
#   NEO4J_TX_TOTAL_MAX=8G  NEO4J_TX_MAX=2G
NEO4J_HEAP_INIT=2G
NEO4J_HEAP_MAX=2G
NEO4J_PAGECACHE=2G
NEO4J_TX_TOTAL_MAX=2G
NEO4J_TX_MAX=512M

# ===== Docker monitoring =====
# URL the /admin/container-status page hits for read-only container
# state. Defaults to the tecnativa/docker-socket-proxy sidecar wired in
# infra/docker-compose.yml (the `docker_socket_proxy` service), which
# exposes only GET /containers* + /info + /version — POST and EXEC are
# hard-denied at the proxy.
#
# Set this to an empty string to disable the admin page entirely. The
# service returns a single "not configured" card so operators who'd
# rather not expose even a read-only slice of the docker socket can
# opt out without editing PHP.
DOCKER_API_HOST=http://docker_socket_proxy:2375
# Per-request timeout in seconds. Widget polls every ~10s, so a dead
# proxy shouldn't hold the page past its own cache TTL. 2s is plenty
# for a healthy proxy on the internal compose network.
DOCKER_API_TIMEOUT_SECONDS=2

# ===== EVE SSO =====
# OAuth2 PKCE login against login.eveonline.com. Register an app at
#   https://developers.eveonline.com/applications
# pointing the callback URL at `${APP_URL}/auth/eve/callback`. Phase-1
# login only asks for `publicData` — enough to identify the character.
# Elevated scopes (killmails, markets, structures, etc.) come in on the
# phase-2 "service character" flow, which is a separate SSO round-trip
# from /admin. See docs/adr/0002-eve-sso-and-esi-client.md.
EVE_SSO_CLIENT_ID=
EVE_SSO_CLIENT_SECRET=
EVE_SSO_CALLBACK_URL="${APP_URL}/auth/eve/callback"
# Token exchange endpoint. Only override when CCP rotates the SSO
# domain or you're proxying through a mirror (neither is common).
EVE_SSO_TOKEN_URL=https://login.eveonline.com/v2/oauth/token
# Space- or comma-separated scopes requested on user login.
EVE_SSO_LOGIN_SCOPES=publicData

# Space- or comma-separated scopes requested on the *service character*
# SSO flow (admin-only, kicked off from /admin/eve-service-character).
# The default below grants enough for character/corp/alliance/market
# polling — trim or extend per deployment. Tokens land encrypted at
# rest in the eve_service_tokens table; see ADR-0002 § phase-2 amendment.
# Leave empty to disable the service flow entirely (the admin page will
# show a "no scopes configured" notice).
EVE_SSO_SERVICE_SCOPES="publicData esi-location.read_location.v1 esi-location.read_ship_type.v1 esi-search.search_structures.v1 esi-universe.read_structures.v1 esi-markets.structure_markets.v1 esi-characters.read_corporation_roles.v1 esi-corporations.read_corporation_membership.v1 esi-corporations.read_structures.v1 esi-alliances.read_contacts.v1"

# Comma-separated EVE character IDs with access to /admin. IDs (not
# names) — EVE lets characters rename themselves; the ID is immutable.
# Find your character ID on https://evewho.com or via ESI
# /characters/affiliation/.
EVE_SSO_ADMIN_CHARACTER_IDS=

# ===== Donations character (third SSO flow) =====
# Optional: an in-game character that *receives* ISK donations from
# supporters. The poller hits its wallet journal every few minutes and
# records `player_donation` entries; donor characters that match a
# logged-in user's linked character are automatically flagged via
# User::isDonor() (the gate the future ad-removal logic will read).
#
# The flow is locked to one character ID — admins can click "Authorise"
# while logged into EVE as any character, but only the configured one's
# token gets stored. Wrong-character authorisations bounce with an error
# rather than leaking a bearer token into the database.
#
# Leave EVE_SSO_DONATIONS_CHARACTER_ID empty to disable the flow
# entirely (the admin page hides its CTA + the scheduler skips polling).
EVE_SSO_DONATIONS_CHARACTER_ID=
# Cosmetic — used in admin UI before the first auth lands. Once a token
# is stored, the JWT-derived name overrides this on every re-auth.
EVE_SSO_DONATIONS_CHARACTER_NAME=
# Scope set for the donations character. Wallet read is the functional
# scope; `publicData` rides alongside as the base-identity scope that
# CCP's SSO consent screen expects on every authorised session (some
# edge cases drop the wallet scope silently without it). Keep the set
# narrow — broader scopes = larger blast radius if the token leaks.
# Donor name resolution does NOT depend on this; it uses the unauth'd
# /universe/names/ endpoint regardless of what we ask for here.
EVE_SSO_DONATIONS_SCOPES="publicData esi-wallet.read_character_wallet.v1"
# Cron expression for the donations wallet poller. Default every 5
# minutes — wallet journal is cached 1h server-side per CCP, but
# 304-cheap polls are fine and donor feedback latency is the operator
# experience we're optimising for. Quote the value (compose otherwise
# eats the asterisks).
EVE_DONATIONS_POLL_CRON="*/5 * * * *"
# ISK-per-ad-free-day rate. Each donation grants `amount / this` days of
# ad-free time for the donor. Default 100_000 ISK = 1 day. Lower values
# are more generous (small community); higher values less (big community
# with deep-pocketed donors). Zero / negative falls back to the default
# so nobody accidentally disables the feature by typo.
#
# Donations stack: a second donation inside an active window extends it
# from the current expiry. A donation after the window expired starts a
# fresh one from its own timestamp.
#
# Changes are retroactive — after editing this, run
# `php artisan eve:donations:recompute` to rebuild every donor's stored
# ad_free_until at the new rate.
EVE_DONATIONS_ISK_PER_DAY=100000

# ===== ESI =====
# Base URL for ESI calls (both Laravel's light-sync client and the
# Python pollers). Phase 1 targets `/latest`. Only override when CCP
# switches to a new major version we've opted into.
ESI_BASE_URL=https://esi.evetech.net/latest
# CCP requires a User-Agent identifying the app + a contact method.
# Format: "<AppName>/<Version> (+<contact-email-or-url>)".
ESI_USER_AGENT="AegisCore/0.1 (+ops@example.com)"
# HTTP timeout for a single ESI call. Keep tight — light synchronous
# callers must fit inside the <2s job budget from CONTRACTS.md.
ESI_TIMEOUT_SECONDS=10

# Reactive rate-limit throttle (App\Services\Eve\Esi\EsiRateLimiter).
# - SAFETY_MARGIN: refuse to send when the group's last-known
#   X-Ratelimit-Remaining drops to or below this. 5 is a calm default
#   for the typical 150/15m bucket.
# - MAX_WAIT_SECONDS: EsiClient sleeps in-process for waits up to this;
#   longer holds throw EsiRateLimitException so Horizon callers can
#   `release($seconds)` instead of pinning a worker.
# - ERROR_LIMIT_SAFETY_MARGIN: refuse to send when CCP's global error
#   budget (X-ESI-Error-Limit-Remain, default 100/min fixed window)
#   drops to or below this. Overflow trips 420 for every route, so we
#   reserve a wider cushion than the per-group bucket margin.
ESI_RATE_LIMIT_SAFETY_MARGIN=5
ESI_RATE_LIMIT_MAX_WAIT_SECONDS=5
ESI_ERROR_LIMIT_SAFETY_MARGIN=10

# Payload cache (App\Services\Eve\Esi\CachedEsiClient). Sits on top of
# the transport to store full response bodies next to the validators so
# fresh hits skip the network, 304s replay a usable body, and transient
# upstream failures serve the last-good body instead of failing callers.
# - FALLBACK_FRESHNESS_SECONDS: assumed dwell when ESI omits `Expires`.
# - STALE_IF_ERROR_SECONDS: max age of a body we'll serve under a
#   transient 5xx / timeout. 4xx and rate-limit errors are never served
#   stale.
# - RETENTION_SECONDS: hard upper bound on entry lifetime. Should be
#   >= ESI_CACHE_TTL_SECONDS so payloads outlive the validators that
#   revalidate them.
# - LOCK_WAIT_SECONDS: bounds single-flight coalescing. Peers waiting
#   longer fall through to a direct fetch instead of starving.
# - CACHE_ENABLED: kill switch. False binds the bare transport to
#   EsiClientInterface, bypassing the decorator entirely.
ESI_PAYLOAD_FALLBACK_FRESHNESS_SECONDS=60
ESI_PAYLOAD_STALE_IF_ERROR_SECONDS=600
ESI_PAYLOAD_RETENTION_SECONDS=604800
ESI_PAYLOAD_LOCK_WAIT_SECONDS=5
ESI_PAYLOAD_CACHE_ENABLED=true

# ===== SDE importer =====
# Python `sde_importer` one-shot that downloads CCP's EVE SDE JSONL zip
# and reloads the `ref_*` MariaDB tables. Triggered via
# `make sde-import`; settings below only tune the one-shot and are
# unused at runtime. See ADR-0001.
#
# Upstream pinned tarball. Override only to point at a mirror (e.g.
# air-gapped import).
SDE_SOURCE_URL=https://developers.eveonline.com/static-data/eve-online-static-data-latest-jsonl.zip
# Rows per INSERT batch inside the single import transaction. Larger
# batches trade memory for throughput.
SDE_BATCH_SIZE=2000
# HTTP timeout for the ~300 MB JSONL zip download.
SDE_DOWNLOAD_TIMEOUT=600

# ===== Graph universe sync =====
# Python `graph_universe_sync` one-shot that projects the SDE universe
# topology from MariaDB into Neo4j. Triggered via
# `make neo4j-sync-universe`.
#
# Rows per MERGE batch. Higher = faster but more Neo4j heap pressure.
GRAPH_BATCH_SIZE=2000
# When true, skip Jove / Anoikis / Abyssal regions and limit the
# projection to New Eden k-space + w-space. False includes every region
# in the SDE.
GRAPH_NEW_EDEN_ONLY=true

# ===== Market poller =====
# Python `market_poller` — pulls order-book snapshots from ESI into
# `market_orders`. Runs both as a long-lived scheduler
# (`market_poll_scheduler`) and as a one-shot (`make market-poll`).
# See ADR-0004.
#
# Loop cadence for the long-lived scheduler (seconds). 300 = 5 min,
# matching CCP's /markets/{region_id}/orders/ cache window. 0 would
# turn the scheduler into a one-shot; leave it positive.
MARKET_POLL_INTERVAL_SECONDS=300
# Rows per executemany() INSERT batch. 5000 is a comfortable fit for
# a region endpoint response (~8k-30k orders in Jita).
MARKET_POLL_BATCH_SIZE=5000
# Refuse to send ESI calls when the per-route `X-Ratelimit-Remaining`
# header drops to or below this cushion. Higher = safer but slower.
MARKET_POLL_RATE_LIMIT_SAFETY_MARGIN=5
# Global error-budget cushion (`X-ESI-Error-Limit-Remain`).
# Overflow trips 420 on every route, so reserve wider.
MARKET_POLL_ERROR_LIMIT_SAFETY_MARGIN=10
# Circuit breakers per location — the poller trips on N consecutive
# 403s (auth / scope issue) or 5xx (CCP trouble) and skips the location
# for the rest of the pass rather than hammering on.
MARKET_POLL_MAX_CONSECUTIVE_403S=3
MARKET_POLL_MAX_CONSECUTIVE_5XX=5

# ===== Market importer (EVE Ref daily history) =====
# Python `market_importer` — pulls EVE Ref's daily market-history CSV
# dumps into `market_history`. Runs as a long-lived scheduler
# (`market_import_scheduler`) and a one-shot (`make market-import`).
#
# EVE Ref upstream. The totals.json endpoint drives the reconcile
# check that skips already-complete days cheaply.
EVEREF_BASE_URL=https://data.everef.net/market-history
EVEREF_TOTALS_URL=https://data.everef.net/market-history/totals.json
# Loop cadence for the long-lived scheduler (seconds). 21600 = 6 h.
# EVE Ref publishes once per day but updates the same-day file as
# their ESI scrape completes; 6h catches those updates without
# hammering.
MARKET_IMPORT_INTERVAL_SECONDS=21600
# Import window. MIN defaults to the start of ADR-0004's supported
# range; MAX empty = up to yesterday UTC.
MARKET_IMPORT_MIN_DATE=2025-01-01
MARKET_IMPORT_MAX_DATE=
# Rows per executemany() UPSERT batch.
MARKET_IMPORT_BATCH_SIZE=5000
# HTTP timeout for a single day's CSV download (each ~700 KB).
MARKET_IMPORT_DOWNLOAD_TIMEOUT=600
