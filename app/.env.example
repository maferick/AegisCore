APP_NAME=AegisCore
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Log to stderr so docker logs / Portainer capture everything.
LOG_CHANNEL=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# ===== MariaDB =====
# In compose these are set from MARIADB_* in the root .env; the Laravel
# names (DB_*) are what Laravel actually reads.
DB_CONNECTION=mariadb
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=aegiscore
DB_USERNAME=aegiscore
DB_PASSWORD=

# ===== Redis (Laravel cache / sessions / queues / Horizon) =====
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# ===== Horizon =====
# Tune per deployment. Control-plane queues only — keep jobs <2s / <100 rows
# per AGENTS.md plane boundary. Heavy cross-plane work goes via the outbox.
# /horizon auth is gated on Filament admin access (see
# app/Providers/HorizonServiceProvider.php) — same login as /admin, same ACL.
HORIZON_PREFIX=aegiscore:horizon:

# ===== Derived stores (non-Laravel conventions) =====
# Phase 1: OpenSearch security plugin disabled, plain HTTP on internal net.
OPENSEARCH_HOST=http://opensearch:9200

INFLUXDB_HOST=http://influxdb2:8086
INFLUXDB_TOKEN=
INFLUXDB_ORG=aegiscore
INFLUXDB_BUCKET=primary

NEO4J_HOST=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@aegiscore.local"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# ===== NVIDIA NIM (optional safe-AI backend) =====
# Leave NVIDIA_NIM_API_KEY empty to disable. Out-of-band only —
# never used from Livewire / queue jobs gating analyst state.
# See ADR 0012 + ADR 0013 + calibration_proposals row 2026-04-30.
#
# Tiered model routing:
#   primary  = fast loop model — hypothesis refinement, anomaly
#              explanation, signal fusion reasoning
#   fallback = JSON-safety net invoked when primary fails (404 / transport)
#   heavy    = final summary, "what changed" cards, CI command surface
#   safety   = optional content-safety pass (stubbed; not yet wired)
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_PRIMARY_MODEL=stepfun-ai/step-3.5-flash
NVIDIA_NIM_FALLBACK_MODEL=z-ai/glm4.7
NVIDIA_NIM_HEAVY_MODEL=mistralai/mistral-large-3-675b-instruct-2512
NVIDIA_NIM_SAFETY_MODEL=nvidia/nemotron-content-safety-reasoning
NVIDIA_NIM_TIMEOUT=120
NVIDIA_NIM_HEAVY_TIMEOUT=180
NVIDIA_NIM_MAX_RETRIES=2
NVIDIA_NIM_TEMPERATURE=0.2
NVIDIA_NIM_HEAVY_TEMPERATURE=0.15
NVIDIA_NIM_MAX_TOKENS=8192
NVIDIA_NIM_HEAVY_MAX_TOKENS=4096
NVIDIA_NIM_JSON_MODE=true
