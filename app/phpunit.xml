<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="tests/bootstrap.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <!--
            Both <env> AND <server> entries are required. Laravel's env()
            helper reads $_SERVER via `ServerConstAdapter` BEFORE it
            reads $_ENV / getenv(), and docker-compose sets variables
            into $_SERVER as well as $_ENV. If we only set <env>, the
            $_SERVER value injected by the container wins and Laravel
            connects to production MariaDB. This is literally how the
            2026-04-16 wipe happened: force="true" on <env> alone left
            $_SERVER['DB_CONNECTION']='mariadb' untouched, so
            config('database.default') resolved to 'mariadb', and
            migrate:fresh dropped every production table. Never add a
            DB-steering variable without BOTH <env force="true"> and
            <server force="true"> entries.
        -->
        <env name="APP_ENV" value="testing" force="true"/>
        <env name="APP_KEY" value="base64:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=" force="true"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file" force="true"/>
        <env name="BCRYPT_ROUNDS" value="4" force="true"/>
        <env name="BROADCAST_CONNECTION" value="null" force="true"/>
        <env name="CACHE_STORE" value="array" force="true"/>
        <env name="DB_CONNECTION" value="testing_mariadb" force="true"/>
        <env name="DB_DATABASE" value="aegiscore_test" force="true"/>
        <env name="DB_HOST" value="" force="true"/>
        <env name="DB_PORT" value="" force="true"/>
        <env name="DB_USERNAME" value="" force="true"/>
        <env name="DB_PASSWORD" value="" force="true"/>
        <env name="DB_URL" value="" force="true"/>
        <env name="MAIL_MAILER" value="array" force="true"/>
        <env name="QUEUE_CONNECTION" value="sync" force="true"/>
        <env name="SESSION_DRIVER" value="array" force="true"/>
        <env name="PULSE_ENABLED" value="false" force="true"/>
        <env name="TELESCOPE_ENABLED" value="false" force="true"/>
        <env name="NIGHTWATCH_ENABLED" value="false" force="true"/>

        <!-- $_SERVER overrides — these are the ones Laravel's env()
             actually reads first. See the long comment above. -->
        <server name="APP_ENV" value="testing" force="true"/>
        <server name="APP_KEY" value="base64:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=" force="true"/>
        <server name="DB_CONNECTION" value="testing_mariadb" force="true"/>
        <server name="DB_DATABASE" value="aegiscore_test" force="true"/>
        <server name="DB_HOST" value="" force="true"/>
        <server name="DB_PORT" value="" force="true"/>
        <server name="DB_USERNAME" value="" force="true"/>
        <server name="DB_PASSWORD" value="" force="true"/>
        <server name="DB_URL" value="" force="true"/>
    </php>
</phpunit>
